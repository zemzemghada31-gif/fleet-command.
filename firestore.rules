rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isMechanic() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'mechanic';
    }

    function isAdminOrMechanic() {
      return isAdmin() || isMechanic();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Vehicles ──────────────────────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── Devices ───────────────────────────────────────────────────────────────
    match /devices/{deviceId} {
      allow read:   if isSignedIn();
      allow create: if isAdmin();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── Maintenance Tasks ─────────────────────────────────────────────────────
    match /maintenanceTasks/{taskId} {
      allow read:   if isSignedIn();
      allow create: if isAdminOrMechanic();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── Maintenance Logs ──────────────────────────────────────────────────────
    match /maintenanceLogs/{logId} {
      allow read:   if isSignedIn();
      allow create: if isAdminOrMechanic();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── DTC Codes ─────────────────────────────────────────────────────────────
    match /dtcCodes/{dtcId} {
      allow read:   if isSignedIn();
      allow create: if isAdminOrMechanic();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── Alerts ────────────────────────────────────────────────────────────────
    match /alerts/{alertId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    // ── Trajectory Points (subcollection) ─────────────────────────────────────
    match /trajectoryPoints/{vehicleId}/points/{pointId} {
      allow read:   if isSignedIn();
      allow create: if isAdminOrMechanic();
      allow update: if isAdminOrMechanic();
      allow delete: if isAdmin();
    }

    // ── Analytics Stats ───────────────────────────────────────────────────────
    match /analyticsStats/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Analytics Trends ──────────────────────────────────────────────────────
    match /analyticsTrends/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
  }
}

